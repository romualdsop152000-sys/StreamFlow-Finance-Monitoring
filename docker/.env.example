# ============================================================
#  StreamFlow Finance — Template de configuration
#  Copier ce fichier en .env et remplir les valeurs
#  cp .env.example .env
# ============================================================

# --- PostgreSQL interne Airflow ---
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=change_me
AIRFLOW_POSTGRES_DB=airflow

# --- PostgreSQL Data Warehouse ---
POSTGRES_HOST=postgres-warehouse
POSTGRES_PORT=5432
POSTGRES_DB=datalake
POSTGRES_USER=change_me
POSTGRES_PASSWORD=change_me

# --- Airflow UI ---
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change_me
AIRFLOW_ADMIN_EMAIL=your@email.com

# --- pgAdmin ---
PGADMIN_DEFAULT_EMAIL=your@email.com
PGADMIN_DEFAULT_PASSWORD=change_me

# --- Elasticsearch / Kibana ---
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
